{
  "mcpServers": {
    "world-bank": {
      "command": "uv",
      "args": [
        "--directory",
        "tools/mcp/world_bank_mcp_server-master",
        "run",
        "world_bank_mcp_server"
      ]
    },
    "data360": {
      "command": "uv",
      "args": [
        "--directory",
        "tools/mcp/data360-mcp-dev",
        "run",
        "fastmcp",
        "run",
        "src/data360/server.py"
      ],
      "env": {
        "DATA360_API_BASE_URL": "https://data360api.worldbank.org"
      }
    },
    "oecd": {
      "command": "node",
      "args": [
        "tools/mcp/OECD-MCP-main/dist/index.js"
      ]
    }
  }
}