flowchart LR
    AI(["<b>AI agent</b><br/><i>about to read or edit .tex</i>"]):::agent
    Hook["<b>PreToolUse hook</b><br/>GET /updates  &nbsp;<i>~0.3 s</i>"]:::proc
    Decide{"<b>web-origin<br/>change?</b>"}:::decide
    Skip(["skip<br/><i>(no download)</i>"]):::skip
    Pull["<b>GET /download/zip</b><br/>extract changed files only"]:::proc
    Edit(["<b>AI reads / edits</b><br/><i>fresh local file</i>"]):::agent

    AI ==> Hook ==> Decide
    Decide -->|no| Skip
    Decide -->|yes| Pull
    Skip ==> Edit
    Pull ==> Edit

    classDef agent  fill:#dbeafe,color:#1e3a8a,stroke:#2563eb,stroke-width:2px
    classDef proc   fill:#fef3c7,color:#78350f,stroke:#d97706,stroke-width:2px
    classDef decide fill:#fae8ff,color:#581c87,stroke:#a21caf,stroke-width:2px
    classDef skip   fill:#dcfce7,color:#14532d,stroke:#16a34a,stroke-width:2px
    linkStyle default stroke:#6b7280,stroke-width:2px
