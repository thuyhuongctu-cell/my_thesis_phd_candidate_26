{
  "$schema": "https://openecon.ai/schemas/validation/claim_gate_policy.schema.json",
  "version": 1,
  "policy_name": "claim_gate_policy_v1",
  "certification_target": "user_answerability",
  "certification_target_description": "Claim gate certifies whether a real user gets the needed answer for the prompt, not whether every frozen legacy catalog row/code can be replayed.",
  "legacy_catalog_replay_scope": "inventory_and_provider_supportability_diagnostic_only",
  "snapshot_manifest_path": "validation/manifests/catalog_snapshot-2026-04-14.json",
  "strata_manifest_path": "validation/manifests/strata_definition-v1.json",
  "claim_thresholds": {
    "weighted_session_success_min": 0.992,
    "lower95_min": 0.99,
    "wrong_confident_answer_rate_max": 0.005,
    "unnecessary_clarification_rate_max": 0.05,
    "ambiguity_resolution_success_min": 0.99
  },
  "direct_provider_floor_defaults": {
    "critical": 0.97,
    "high_traffic": 0.98
  },
