{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openecon.ai/schemas/validation/multiround_session.schema.json",
  "title": "Multiround validation session",
  "type": "object",
  "required": [
    "id",
    "family",
    "rounds"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "family": {
      "type": "string"
    },
    "risk_class": {
      "type": [
        "string",
        "null"
      ]
    },
    "rounds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "query",
          "gold"
        ],
        "properties": {
          "query": {
            "type": "string"
          },
          "gold": {
            "type": "object"
          }
        },
        "additionalProperties": true
      }
    },
    "dataset_tier": {
      "type": [
        "string",
        "null"
      ]
    },
    "provenance": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "snapshot_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "sampler_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "sampling_probability": {
          "type": [
            "number",
            "null"
          ]
        },
        "selection_weight": {
          "type": [
            "number",
            "null"
          ]
        },
        "holdout_split": {
          "type": [
            "string",
            "null"
          ]
        },
        "seed": {
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
