{
  "name": "@data360/mcp-ui",
  "version": "0.0.7",
  "description": "React UI for presenting Data360 MCP tool output (chart card, search results card, and future surfaces).",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./viz-card": {
      "types": "./dist/viz-card.d.ts",
      "import": "./dist/viz-card.js",
      "require": "./dist/viz-card.cjs"
    },
    "./search-card": {
      "types": "./dist/search-card.d.ts",
      "import": "./dist/search-card.js",
      "require": "./dist/search-card.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@data360/chart-payload-normalize": "0.0.2",
    "@data360/mcp-viz-core": "0.0.3",
    "html-to-image": "^1.11.13"
  },
  "peerDependencies": {
    "@data360/tool-types": ">=0.0.1",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "vega": ">=5.0.0",
    "vega-embed": ">=6.0.0",
    "vega-lite": ">=5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react-markdown": "^9.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0"
  },
  "keywords": [
    "data360",
    "mcp",
    "world-bank",
    "vega-lite",
    "search"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/worldbank/data360-mcp"
  }
}
