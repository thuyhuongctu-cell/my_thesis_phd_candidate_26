    classDef thesis fill:#0b3d6b,stroke:#062744,color:#ffffff,stroke-width:2px;
    classDef branch fill:#f1f3f5,stroke:#343a40,color:#212529,stroke-width:1px;
    classDef pub fill:#d4edda,stroke:#155724,color:#0b2e14;
    classDef acc fill:#cfe2ff,stroke:#084298,color:#06214f;
    classDef rev fill:#ffe2b8,stroke:#9c5b00,color:#3d2400;
    classDef prep fill:#fff3cd,stroke:#856404,color:#3d3000;
    classDef plan fill:#e9ecef,stroke:#495057,color:#212529;
    classDef theory fill:#e7e0ff,stroke:#4b2ea0,color:#23104f;
    classDef essay fill:#d8f3f0,stroke:#0f6b63,color:#053b36;
    classDef mile fill:#fde2e4,stroke:#9d2235,color:#4a0d18;

    class LA thesis;
    class LT,CD,BB,RM branch;
    class P1 pub;
    class P2 acc;
    class P4 rev;
    class P3,P5,P6,P7 prep;
    class P8,P9,P10 plan;
