  - family-names: "Phan"
    given-names: "Anh Tú"
    orcid: "https://orcid.org/0000-0003-0667-3137"
    affiliation: "College of Economics, Can Tho University, Vietnam"
keywords:
  - meta-analysis
  - international business
  - internationalization and firm performance
  - effect-size extraction
  - human-in-the-loop
  - responsible AI in research
  - research software
repository-code: "https://github.com/thuyhuongctu-cell/my_thesis_phd_candidate_26"
