# ------------------------------
# DSpace REST API (required)
# ------------------------------
DS_API_ENDPOINT=https://<dspace-domain>/server/api
DS_API_TOKEN=<your_dspace_api_token>
DS_ACCESS_TOKEN=<dspace_access_token>         # optional — alternative session auth

# ------------------------------
# EPFL People API
# ------------------------------
API_EPFL_USER=<epfl_api_user>
API_EPFL_PWD=<epfl_api_password>

# ------------------------------
# Harvesting sources
# ------------------------------
SCOPUS_API_KEY=<your_scopus_api_key>
SCOPUS_INST_TOKEN=<your_scopus_institutional_token>
ELS_API_KEY=<your_elsevier_api_key>           # Elsevier PDF retrieval

WOS_TOKEN=<your_wos_token>

EPO_OPS_KEY=<your_epo_ops_key>
EPO_OPS_SECRET=<your_epo_ops_secret>

OPENALEX_API_KEY=<your_openalex_api_key>
# OPENALEX_DATA_VERSION=2                     # optional — API data version (default: 2)

ZENODO_API_KEY=<your_zenodo_api_key>

ORCID_API_TOKEN=<your_orcid_token>

# ------------------------------
# Polite pool (Crossref, Unpaywall, OpenAlex)
# ------------------------------
CONTACT_API_EMAIL=<your_email>
USER_AGENT=<your_user_agent_string>           # defaults to EPFL string if unset

# ------------------------------
# SMTP — email report (optional)
# ------------------------------
RECIPIENT_EMAIL=<recipient_email>
SENDER_EMAIL=<sender_email>
SMTP_SERVER=<smtp_host>
