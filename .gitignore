# Git ignore rules

# Environment
.env
.env.local
.env.*.local
.env.production

# Claude local settings
.claude/settings.local.json
.claude/CLAUDE.local.md
.claude/session-reads.txt

# Dependencies
node_modules/

# Build output (Node.js projects only — PhD dissertation DOCX output is tracked)
build/
out/
# dist/ intentionally NOT ignored — dist/chuyen_de_1/ contains CTU-formatted DOCX deliverables

# Logs
logs/
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/

# Test coverage
coverage/
.nyc_output/

# Temporary files
tmp/
temp/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# P6 downloaded PDFs (too large for git — store locally)
p6/pdfs/

# MCP server runtime artefacts (uv)
tools/mcp/**/.venv/
tools/mcp/**/__pycache__/
tools/mcp/**/*.egg-info/
tools/mcp/**/.env

# vendored tool artefacts
tools/econ/cline-main/
tools/mcp/**/node_modules/
tools/mcp/**/dist/
!tools/mcp/OECD-MCP-main/dist/
tools/econ/stata-mcp/
